{
  "name": "mamba-gator",
  "version": "6.1.1.dev0",
  "description": "Manage your conda environments.",
  "type": "module",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mamba-org/gator.git"
  },
  "author": "Jupyter Development Team",
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/mamba-org/gator/issues"
  },
  "homepage": "https://github.com/mamba-org/gator",
  "scripts": {
    "build": "lerna run build",
    "build:dev": "lerna run build:dev",
    "build:prod": "jlpm install && lerna run build:prod",
    "clean": "lerna run clean",
    "eslint": "eslint . --fix",
    "eslint:check": "eslint .",
    "prettier": "npx prettier --write \"**/*{.ts,.tsx,.js,.jsx,.css,.json,.md}\"",
    "prettier:check": "npx prettier --list-different \"**/*{.ts,.tsx,.js,.jsx,.css,.json,.md}\"",
    "publish": "jlpm run clean && jlpm run build && lerna publish",
    "test": "lerna run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "acorn": "^8.16.0",
    "acorn-import-attributes": "^1.9.5",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.37.0",
    "husky": "^8.0.0",
    "lerna": "^9.0.5",
    "lint-staged": "^16.3.3",
    "node-fetch": "3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.57.0",
    "watch": "~1.0.2"
  },
  "resolutions": {
    "@types/react-dom": "^18.0.4",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.3",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/application": "^4.0.0",
    "merge@^1.2.0": "^2.1.1",
    "picomatch@^4.0.2": "^4.0.4",
    "picomatch@^2.3.1": "^2.3.2",
    "lodash-es": "^4.18.0",
    "d3-color": "^3.1.0"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "private": true
}
